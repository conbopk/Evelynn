# =============================================================================
# Evelynn — Inference Service Environment Variables
# Copy to .env for development, .env.prod for production.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development                  # development | testing | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console               # console (dev) | json (prod)

HOST=0.0.0.0
PORT=8000
WORKERS=1                        # keep 1; model is loaded once per process

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# In development with empty API_KEYS, auth is skipped automatically.
# In production, always set strong random keys.
API_KEYS=your-secret-key-1,your-secret-key-2

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * to allow all (dev only).
CORS_ORIGINS=http://localhost:8000,https://your-domain.com

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_ID=Tongyi-MAI/Z-Image-Turbo
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx     # required for gated models
PRELOAD_MODEL=true               # true = load at startup; false = lazy on first request

DEFAULT_STEPS=9
DEFAULT_GUIDANCE_SCALE=0.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
MAX_WIDTH=2048
MAX_HEIGHT=2048

# ── HuggingFace cache ─────────────────────────────────────────────────────────
# Mount a persistent volume here to avoid re-downloading weights on restart.
HF_HUB_CACHE=/models
HF_XET_HIGH_PERFORMANCE=1

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
S3_KEY_PREFIX=images