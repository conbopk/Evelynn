# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
# PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/frontend"

# BETTER-AUTH
BETTER_AUTH_SECRET="your-random-secret-here"
NEXT_PUBLIC_BETTER_AUTH_URL="https://your-domain.com"

# POLAR - Billing
POLAR_ACCESS_TOKEN="your-polar-access-token"
# Polar sends events to /api/auth (handled by better-auth Polar plugin).
POLAR_WEBHOOK_SECRET="you-polar-webhook-secret"

# AWS
# IAM credentials with s3:GetObject, s3:PutObject, s3:DeleteObject on your bucket.
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="your-aws-region"
AWS_S3_BUCKET_NAME="your-aws-bucket-name"

# Modal
MODAL_BACKEND_URL="your-backend-modal-https-endpoint-url"
MODAL_KEY_ID="your-modal-key-id"
MODAL_SECRET_KEY="your-modal-secret-key"